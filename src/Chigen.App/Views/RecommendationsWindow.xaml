<Window x:Class="Chigen.App.Views.RecommendationsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=RecommendationsTitle}"
        Height="260" Width="450"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=RecommendationsTitle}" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBox Grid.Row="1" x:Name="txtRecommendations" AcceptsReturn="True" TextWrapping="Wrap"
                 FontSize="13" Padding="6" BorderBrush="#B0B0B0" BorderThickness="1"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Ok}" Padding="16,6" FontWeight="Bold" Margin="4" IsDefault="True" Click="Ok_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Cancel}" Padding="16,6" Margin="4" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

