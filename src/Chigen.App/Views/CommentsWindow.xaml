<Window x:Class="Chigen.App.Views.ConclusionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ConclusionTitle}"
        Height="280" Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ConclusionTitle}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <TextBox Grid.Row="1" x:Name="txtConclusion" AcceptsReturn="True" TextWrapping="Wrap"
                 Style="{StaticResource ModernTextBox}" FontSize="13" Padding="8" VerticalContentAlignment="Top"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Ok}" Style="{StaticResource AccentButton}" Padding="20,8" Margin="4" IsDefault="True" Click="Ok_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Cancel}" Style="{StaticResource ModernButton}" Padding="16,8" Margin="4" IsCancel="True" Click="Cancel_Click"/>
        </StackPanel>
    </Grid>
</Window>

