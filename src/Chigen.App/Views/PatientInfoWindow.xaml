<Window x:Class="Chigen.App.Views.PatientInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoTitle}"
        Height="560" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=EnterPatientDetails}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientNamePanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientName}"/>
                    <TextBox Grid.Column="1" x:Name="txtName"/>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientIdPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientId}"/>
                    <TextBox Grid.Column="1" x:Name="txtId"/>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientDobPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=DateOfBirth}"/>
                    <TextBox Grid.Column="1" x:Name="txtDob"/>
                </Grid>

                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientSexPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Sex}"/>
                    <TextBox Grid.Column="1" x:Name="txtSex"/>
                </Grid>

                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientDiagnosisPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Diagnosis}"/>
                    <TextBox Grid.Column="1" x:Name="txtDiagnosis"/>
                </Grid>

                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientAddressPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientAddress}"/>
                    <TextBox Grid.Column="1" x:Name="txtAddress"/>
                </Grid>

                <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientPhysicianPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Physician}"/>
                    <TextBox Grid.Column="1" x:Name="txtPhysician"/>
                </Grid>

                <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientWardPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Ward}"/>
                    <TextBox Grid.Column="1" x:Name="txtWard"/>
                </Grid>

                <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientPaymentPanel" Margin="0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PaymentMethod}"/>
                    <TextBox Grid.Column="1" x:Name="txtPaymentMethod"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!-- Warning card -->
        <Border Grid.Row="2" Background="{DynamicResource WarningBgBrush}" Padding="12,8" Margin="0,12,0,0" CornerRadius="6"
                BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
            <TextBlock FontSize="12" Foreground="{DynamicResource WarningFgBrush}" TextWrapping="Wrap" LineHeight="16">
                <Run Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoHelp1}"/><LineBreak/>
                <Run Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoHelp2}"/>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button x:Name="btnStart" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Start}" Style="{StaticResource AccentButton}" Padding="24,10" FontWeight="Bold" FontSize="14"
                    Margin="4" IsDefault="True" Click="Start_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Skip}" Style="{StaticResource ModernButton}" Padding="20,10" Margin="4" IsCancel="True" Click="Skip_Click"/>
        </StackPanel>
    </Grid>
</Window>



