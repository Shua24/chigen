<Window x:Class="Chigen.App.Views.PatientInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoTitle}"
        Height="540" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="Field">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,6"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=EnterPatientDetails}" FontSize="18" FontWeight="Bold" Margin="0,0,0,12"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientNamePanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientName}"/>
                    <TextBox Grid.Column="1" x:Name="txtName" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientIdPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientId}"/>
                    <TextBox Grid.Column="1" x:Name="txtId" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientDobPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=DateOfBirth}"/>
                    <TextBox Grid.Column="1" x:Name="txtDob" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientSexPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Sex}"/>
                    <TextBox Grid.Column="1" x:Name="txtSex" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientDiagnosisPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Diagnosis}"/>
                    <TextBox Grid.Column="1" x:Name="txtDiagnosis" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientAddressPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientAddress}"/>
                    <TextBox Grid.Column="1" x:Name="txtAddress" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientPhysicianPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Physician}"/>
                    <TextBox Grid.Column="1" x:Name="txtPhysician" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientWardPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Ward}"/>
                    <TextBox Grid.Column="1" x:Name="txtWard" Style="{StaticResource Field}"/>
                </Grid>

                <Grid Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2" x:Name="patientPaymentPanel">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PaymentMethod}"/>
                    <TextBox Grid.Column="1" x:Name="txtPaymentMethod" Style="{StaticResource Field}"/>
                </Grid>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="2" Background="#FFF3CD" Padding="10,6" Margin="0,8,0,0"
                BorderBrush="#FFEAA7" BorderThickness="1">
            <TextBlock FontSize="12" Foreground="#856404" TextWrapping="Wrap">
                <Run Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoHelp1}"/><LineBreak/>
                <Run Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoHelp2}"/>
            </TextBlock>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="btnStart" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Start}" Padding="20,8" FontWeight="Bold" FontSize="14"
                    Margin="4" IsDefault="True" Click="Start_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Skip}" Padding="16,8" Margin="4" IsCancel="True" Click="Skip_Click"/>
        </StackPanel>
    </Grid>
</Window>



