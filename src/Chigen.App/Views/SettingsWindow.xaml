<Window x:Class="Chigen.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Chigen.App.ViewModels"
        mc:Ignorable="d"
        Title="Settings — Letterhead Configuration"
        Height="500" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="FieldBox">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="BorderBrush" Value="#B0B0B0"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Letterhead Configuration" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0">Institution Name:</Label>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InstitutionName}" Style="{StaticResource FieldBox}"/>

                    <Label Grid.Row="1" Grid.Column="0">Department:</Label>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Department}" Style="{StaticResource FieldBox}"/>

                    <Label Grid.Row="2" Grid.Column="0">Address:</Label>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Address}" Style="{StaticResource FieldBox}" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"/>

                    <Label Grid.Row="3" Grid.Column="0">Phone:</Label>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Phone}" Style="{StaticResource FieldBox}"/>

                    <Label Grid.Row="4" Grid.Column="0">Email:</Label>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Email}" Style="{StaticResource FieldBox}"/>

                    <Label Grid.Row="5" Grid.Column="0">Logo:</Label>
                    <Grid Grid.Row="5" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LogoPath}" Style="{StaticResource FieldBox}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="Browse..." Margin="4" Padding="8,4" Click="BrowseLogo_Click"/>
                    </Grid>

                    <Label Grid.Row="6" Grid.Column="0">Logo Placement:</Label>
                    <ComboBox Grid.Row="6" Grid.Column="1" Margin="4"
                              SelectedValue="{Binding LogoPlacement}"
                              ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.LogoPlacementOptions}}"
                              DisplayMemberPath="Key"
                              SelectedValuePath="Value"/>

                    <Label Grid.Row="7" Grid.Column="0">Footer Text:</Label>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding FooterText}" Style="{StaticResource FieldBox}"/>

                    <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="Use letterhead in exported documents"
                              IsChecked="{Binding UseLetterhead}"
                              Margin="4,8" FontWeight="SemiBold"/>

                </Grid>

                <Border BorderBrush="#D0D0D0" BorderThickness="1" Padding="10" Margin="0,12,0,0">
                    <StackPanel>
                        <TextBlock Text="Patient Info Fields" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>
                        <CheckBox Content="Patient ID" IsChecked="{Binding ShowPatientId}" Margin="4,2"/>
                        <CheckBox Content="Patient Name" IsChecked="{Binding ShowPatientName}" Margin="4,2"/>
                        <CheckBox Content="Date of Birth" IsChecked="{Binding ShowPatientDob}" Margin="4,2"/>
                        <CheckBox Content="Sex" IsChecked="{Binding ShowPatientSex}" Margin="4,2"/>
                        <CheckBox Content="Diagnosis" IsChecked="{Binding ShowPatientDiagnosis}" Margin="4,2"/>
                        <CheckBox Content="Address" IsChecked="{Binding ShowPatientAddress}" Margin="4,2"/>
                        <CheckBox Content="Physician" IsChecked="{Binding ShowPatientPhysician}" Margin="4,2"/>
                        <CheckBox Content="Ward" IsChecked="{Binding ShowPatientWard}" Margin="4,2"/>
                        <CheckBox Content="Payment Method" IsChecked="{Binding ShowPatientPaymentMethod}" Margin="4,2"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Save" Padding="16,6" FontWeight="Bold" Margin="4" Click="Save_Click"/>
            <Button Content="Cancel" Padding="16,6" Margin="4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
