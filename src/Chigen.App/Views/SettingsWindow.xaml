<Window x:Class="Chigen.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Chigen.App.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=SettingsTitle}"
        Height="540" Width="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}">
    <Window.Resources>
        <Style TargetType="TextBox" BasedOn="{StaticResource ModernTextBox}">
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=LetterheadConfig}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="140"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=InstitutionName}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding InstitutionName}"/>

                    <Label Grid.Row="1" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Department}"/>
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Department}"/>

                    <Label Grid.Row="2" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Address}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Address}" AcceptsReturn="True" TextWrapping="Wrap" MaxHeight="60"/>

                    <Label Grid.Row="3" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Phone}"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Phone}"/>

                    <Label Grid.Row="4" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Email}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Email}"/>

                    <Label Grid.Row="5" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Logo}"/>
                    <Grid Grid.Row="5" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding LogoPath}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Browse}" Margin="4,4,0,4" Padding="12,4" Click="BrowseLogo_Click"/>
                    </Grid>

                    <Label Grid.Row="6" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=LogoPlacement}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" Margin="4"
                              SelectedValue="{Binding LogoPlacement}"
                              ItemsSource="{Binding LogoPlacementOptions}"
                              DisplayMemberPath="Key"
                              SelectedValuePath="Value"/>

                    <Label Grid.Row="7" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=FooterText}"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding FooterText}"/>

                    <CheckBox Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                              Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=UseLetterhead}"
                              IsChecked="{Binding UseLetterhead}"
                              Margin="4,12" FontWeight="SemiBold"/>
                </Grid>

                <!-- Language and Theme Selection -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,12,0,0" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        
                        <Label Grid.Row="0" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Language}"/>
                        <ComboBox Grid.Row="0" Grid.Column="1" Margin="4"
                                  SelectedValue="{Binding SelectedLanguage}"
                                  ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.LanguageOptions}}"
                                  DisplayMemberPath="Key"
                                  SelectedValuePath="Value"
                                  SelectionChanged="Language_Changed"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Theme}" Margin="0,8,0,0"/>
                        <ComboBox Grid.Row="1" Grid.Column="1" Margin="4,8,4,4"
                                  SelectedValue="{Binding SelectedTheme}"
                                  ItemsSource="{Binding Source={x:Static vm:SettingsViewModel.ThemeOptions}}"
                                  DisplayMemberPath="Key"
                                  SelectedValuePath="Value"/>
                    </Grid>
                </Border>

                <!-- Patient Info Field Toggles -->
                <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="12" Margin="0,16,0,0" Background="{DynamicResource SurfaceBgBrush}" CornerRadius="6">
                    <StackPanel>
                        <TextBlock Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=PatientInfoFields}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="15" FontWeight="Bold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientId}" IsChecked="{Binding ShowPatientId}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientName}" IsChecked="{Binding ShowPatientName}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientDob}" IsChecked="{Binding ShowPatientDob}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientSex}" IsChecked="{Binding ShowPatientSex}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientDiagnosis}" IsChecked="{Binding ShowPatientDiagnosis}" Margin="4,4"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientAddress}" IsChecked="{Binding ShowPatientAddress}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientPhysician}" IsChecked="{Binding ShowPatientPhysician}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientWard}" IsChecked="{Binding ShowPatientWard}" Margin="4,4"/>
                                <CheckBox Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ShowPatientPayment}" IsChecked="{Binding ShowPatientPaymentMethod}" Margin="4,4"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Save}" Style="{StaticResource AccentButton}" Padding="20,8" Margin="4" Click="Save_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Cancel}" Style="{StaticResource ModernButton}" Padding="16,8" Margin="4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>


</Window>
