<Window x:Class="Chigen.App.Views.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Chigen.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:HotkeySettingsViewModel}"
        Title="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=HotkeySettingsTitle}"
        Height="540" Width="620"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="{DynamicResource WindowBgBrush}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="ListBoxItem" x:Key="HotkeyRow">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowSelectedBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource RowHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ConfigureHotkeys}" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="20" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=HotkeyHelpText}" Foreground="{DynamicResource SecondaryTextBrush}"
                   FontSize="13" Margin="0,0,0,12" TextWrapping="Wrap"/>

        <!-- Tab headers -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTab}" BorderThickness="1" BorderBrush="{DynamicResource BorderBrush}" Background="{DynamicResource SurfaceBgBrush}">
            <TabItem Header="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=TabPeripheralBlood}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColKey}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColCellType}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColConflict}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding PbItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource HotkeyRow}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Keycap Badge -->
                                    <Border Grid.Column="0" Background="{DynamicResource KeycapBgBrush}" BorderBrush="{DynamicResource KeycapBorderBrush}" BorderThickness="1,1,1,2" CornerRadius="4"
                                            Width="36" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KeyDisplay}"
                                                   Foreground="{DynamicResource KeycapFgBrush}" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding CellName}" Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0"/>

                                    <TextBlock Grid.Column="2" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ConflictText}" FontSize="11"
                                               Foreground="{DynamicResource DangerBrush}" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=TabBoneMarrow}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="{DynamicResource HeaderBgBrush}" Padding="12,8" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColKey}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}"/>
                            <TextBlock Grid.Column="1" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColCellType}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ColConflict}" FontWeight="Bold" Foreground="{DynamicResource HeaderFgBrush}" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding BmItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="Transparent"
                             ItemContainerStyle="{StaticResource HotkeyRow}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Keycap Badge -->
                                    <Border Grid.Column="0" Background="{DynamicResource KeycapBgBrush}" BorderBrush="{DynamicResource KeycapBorderBrush}" BorderThickness="1,1,1,2" CornerRadius="4"
                                            Width="36" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding KeyDisplay}"
                                                   Foreground="{DynamicResource KeycapFgBrush}" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding CellName}" Foreground="{DynamicResource PrimaryTextBrush}"
                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0"/>

                                    <TextBlock Grid.Column="2" Text="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=ConflictText}" FontSize="11"
                                               Foreground="{DynamicResource DangerBrush}" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <Border Grid.Row="3" Background="{DynamicResource WarningBgBrush}" Padding="12,8" Margin="0,12,0,0" CornerRadius="6"
                BorderBrush="{DynamicResource WarningBorderBrush}" BorderThickness="1">
            <TextBlock Text="{Binding StatusText}" FontSize="13" Foreground="{DynamicResource WarningFgBrush}" FontWeight="SemiBold"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Save}" Style="{StaticResource AccentButton}" Padding="20,8" Margin="4" Click="Save_Click"/>
            <Button Content="{Binding Mode=OneWay, Source={StaticResource Translations}, Path=Cancel}" Style="{StaticResource ModernButton}" Padding="16,8" Margin="4" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
