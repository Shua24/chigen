<Window x:Class="Chigen.App.Views.HotkeySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Chigen.App.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance vm:HotkeySettingsViewModel}"
        Title="Hotkey Configuration"
        Height="520" Width="600"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterOwner"
        PreviewKeyDown="Window_PreviewKeyDown"
        Background="#F5F5F5">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Button" x:Key="DialogButton">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="HotkeyRow">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#D9E2F3"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Configure Cell Hotkeys" FontSize="18" FontWeight="Bold" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="Select a cell type and press a key (0-9 or A-Z) to assign. Conflicts are highlighted in red."
                   FontSize="12" Foreground="#666" Margin="0,0,0,8" TextWrapping="Wrap"/>

        <!-- Tab headers -->
        <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedTab}" BorderThickness="1">
            <TabItem Header="Peripheral Blood">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A3C6E" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Key" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="Cell Type" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="2" Text="Conflict" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding PbItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource HotkeyRow}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#1A3C6E" CornerRadius="3"
                                            Width="32" Height="28" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding KeyDisplay}"
                                                   Foreground="White" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding CellName}"
                                               FontSize="14" VerticalAlignment="Center" Margin="8,0"/>

                                    <TextBlock Grid.Column="2" Text="⚠ Conflict" FontSize="11"
                                               Foreground="#CC0000" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>

            <TabItem Header="Bone Marrow">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1A3C6E" Padding="8,6">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Key" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="1" Text="Cell Type" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Grid.Column="2" Text="Conflict" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <ListBox Grid.Row="1" ItemsSource="{Binding BmItems}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource HotkeyRow}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="#1A3C6E" CornerRadius="3"
                                            Width="32" Height="28" HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding KeyDisplay}"
                                                   Foreground="White" FontWeight="Bold" FontSize="14"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <TextBlock Grid.Column="1" Text="{Binding CellName}"
                                               FontSize="14" VerticalAlignment="Center" Margin="8,0"/>

                                    <TextBlock Grid.Column="2" Text="⚠ Conflict" FontSize="11"
                                               Foreground="#CC0000" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="{Binding HasConflict, Converter={StaticResource BoolToVis}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Status -->
        <Border Grid.Row="3" Background="#FFF3CD" Padding="8,4" Margin="0,6,0,0"
                BorderBrush="#FFEAA7" BorderThickness="1">
            <TextBlock Text="{Binding StatusText}" FontSize="12" Foreground="#856404"/>
        </Border>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Save" Style="{StaticResource DialogButton}" Click="Save_Click"/>
            <Button Content="Cancel" Style="{StaticResource DialogButton}" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
