<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window & Surface Colors -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="HeaderFgBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SubHeaderBgBrush" Color="#FFFFFF"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#475569"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#94A3B8"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="BorderBrushDark" Color="#CBD5E1"/>

    <!-- Keycap / Badges -->
    <SolidColorBrush x:Key="KeycapBgBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="KeycapFgBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="KeycapBorderBrush" Color="#CBD5E1"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="AccentDisabledBrush" Color="#93C5FD"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentFgBrush" Color="#FFFFFF"/>
    
    <!-- Row Interaction -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#E2E8F0"/>

    <!-- Danger Brushes -->
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="DangerDisabledBrush" Color="#FCA5A5"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#B91C1C"/>

    <!-- Warnings / Alerts -->
    <SolidColorBrush x:Key="WarningBgBrush" Color="#FEF3C7"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#FDE68A"/>
    <SolidColorBrush x:Key="WarningFgBrush" Color="#92400E"/>
    <!-- Dropdown -->
    <SolidColorBrush x:Key="DropdownItemHoverBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="DropdownItemSelectedBrush" Color="#CBD5E1"/>
</ResourceDictionary>
