<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Window & Surface Colors -->
    <SolidColorBrush x:Key="WindowBgBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="SurfaceBgBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="HeaderBgBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="HeaderFgBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SubHeaderBgBrush" Color="#1E293B"/>
    
    <!-- Text Colors -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#64748B"/>
    
    <!-- Borders -->
    <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>
    <SolidColorBrush x:Key="BorderBrushDark" Color="#475569"/>

    <!-- Keycap / Badges -->
    <SolidColorBrush x:Key="KeycapBgBrush" Color="#334155"/>
    <SolidColorBrush x:Key="KeycapFgBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="KeycapBorderBrush" Color="#475569"/>

    <!-- Accent Brushes -->
    <SolidColorBrush x:Key="AccentBrush" Color="#3B82F6"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="AccentDisabledBrush" Color="#1E3A8A"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#1D4ED8"/>
    <SolidColorBrush x:Key="AccentFgBrush" Color="#FFFFFF"/>
    
    <!-- Row Interaction -->
    <SolidColorBrush x:Key="RowHoverBrush" Color="#334155"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#475569"/>

    <!-- Danger Brushes -->
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="DangerHoverBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="DangerDisabledBrush" Color="#7F1D1D"/>
    <SolidColorBrush x:Key="DangerPressedBrush" Color="#B91C1C"/>

    <!-- Warnings / Alerts -->
    <SolidColorBrush x:Key="WarningBgBrush" Color="#451A03"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#78350F"/>
    <SolidColorBrush x:Key="WarningFgBrush" Color="#FDE68A"/>
    <!-- Dropdown -->
    <SolidColorBrush x:Key="DropdownItemHoverBrush" Color="#1E3A5F"/>
    <SolidColorBrush x:Key="DropdownItemSelectedBrush" Color="#0D1323"/>
</ResourceDictionary>
